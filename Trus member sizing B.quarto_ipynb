   "source": [
    "#| output: asis\n",
    "\n",
    "# Wrap the table after a fixed number of elements so it fits the page width.\n",
    "max_elements_per_row = 6\n",
    "rows = []\n",
    "for start in range(0, len(nse), max_elements_per_row):\n",
    "  element_chunk = nse[start:start + max_elements_per_row]\n",
    "  force_chunk = nsf[start:start + max_elements_per_row]\n",
    "  pad_count = max_elements_per_row - len(element_chunk)\n",
    "\n",
    "  rows.append(['Element'] + [f\"{int(e)}\" for e in element_chunk] + [''] * pad_count)\n",
    "  rows.append(['Axial force (kN)'] + [f\"{f:.2f}\" for f in force_chunk] + [''] * pad_count)\n",
    "col1 = ['Description'] + [f\"Value {index}\" for index in range(1, max_elements_per_row + 1)]\n",
    "table_horizontal = pd.DataFrame(rows, columns=col1)\n",
    "latex_lines = [\n",
    "  r\"\\begin{tabular}{|l|\" + \"c|\" * max_elements_per_row + \"}\",\n",
    "  r\"\\hline\",\n",
    "  \" & \".join(col1) + r\" \\\\\",\n",
    "  r\"\\hline\"\n",
    "]\n",
    "for row_index, row in enumerate(rows, start=1):\n",
    "  latex_lines.append(\" & \".join(row) + r\" \\\\\")\n",
    "  if row_index % 2 == 0:\n",
    "    latex_lines.append(r\"\\hline\")\n",
    "latex_lines.append(r\"\\end{tabular}\")\n",
    "latex_table = \"\\n\".join(latex_lines)    \n",
    "print(r\"\\normalfont\")\n",
    "print(r\"\\renewcommand{\\arraystretch}{1.2}\")\n",
    "print(r\"\\setlength{\\tabcolsep}{11pt}\")\n",
    "print(latex_table)"
   ]
