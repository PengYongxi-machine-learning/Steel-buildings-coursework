    "#\n",
    "#\n",
    "# Loads and deflection at the north side of the truss\n",
    "\\begin{description}\n",
    "    \\item[]The column loads at 1st floor, $F_{1,1}$ = `{python} nsf1` kN\n",
    "    \\item[]The column load due to reaction force from west side, $F_{1,2}$ = `{python} wer` kN\n",
    "    \\item[]$F_1 = F_{1,1} + F_{1,2}$ = `{python} nsf1 + wer` kN\n",
    "    \\item[]The column loads at 2nd floor, $F_2$ = `{python} nsf2` kN\n",
    "    \\item[]The column loads at 3rd floor, $F_3$ = `{python} nsf3` kN\n",
    "    \\item[]Maximum lateral deflection = `{python} nsd` mm < 50 mm\n",
    "\\end{description}\n",
    "\n",
    "{{< pagebreak >}}\n",
    "\n",
    "#\n",
    "#\n",
    "#\n",
