    "#\n",
    "#\n",
    "# Loads and deflection at the west side of the truss\n",
    "\\begin{description}\n",
    "    \\item[]The column loads at 3th floor, $F_1$ = `{python} wef1` kN\n",
    "    \\item[]The column loads at 4th floor, $F_2$ = `{python} wef2` kN\n",
    "    \\item[]Maximum deflection along the span = `{python} wed` mm < 50 mm\n",
    "\\end{description}\n",
