    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "import math\n",
        "%precision 2\n",
        "# Setup\n",
        "floor = 4\n",
        "section = '305 x 305x 240'\n",
        "ixl = 2     # Index for primary lx\n",
        "ixs = 3     # Index for secondary lx\n",
        "it = 4      # Scenario index\n",
        "\n",
        "# Automation start here\n",
        "lp_list = [6000, 8250, 7500]\n",
        "ls_list = [1500, 3000, 2750, 3750, 1875]\n",
        "Type_list = ['Edge', 'Perimeter1', 'Perimeter2', 'Internal', 'Corner']\n",
        "Type = Type_list[it-1]\n",
        "lxl = lp_list[ixl-1]\n",
        "s_lx = ls_list[ixs-1]\n",
        "\n",
        "# Scenario in primary and secondary beams\n",
        "if Type == 'Edge':\n",
        "    Typep = 'Perimeter'\n",
        "    Types = 'Edge'\n",
        "    BC = 2\n",
        "elif Type == 'Perimeter1':\n",
        "    Typep = 'Perimeter'\n",
        "    Types = 'Internal'\n",
        "    BC = 3\n",
        "elif Type == 'Perimeter2':\n",
        "    Typep = 'Internal'\n",
        "    Types = 'Edge'\n",
        "    BC = 5\n",
        "else:\n",
        "    Typep = 'Internal'\n",
        "    Types = 'Internal'\n",
        "    BC = 4\n",
        "\n",
        "# Heights for Floor and Roof\n",
        "if floor == 1:\n",
        "  H = 6000\n",
        "else:\n",
        "  H = 4000\n",
        "\n",
        "# Dead floor\n",
        "gt_f = 0.7\n",
        "gs_f = 3.38\n",
        "gc_f = 0.5\n",
        "gste_f = 0.3\n",
        "gser_f = 1.4\n",
        "\n",
        "# Impose floor\n",
        "qpar_f = 1.0\n",
        "qimp_f = 4.0\n",
        "qcl = 1.2\n",
        "\n",
        "# Dead roof\n",
        "gt_r = 1.0\n",
        "gs_r = 3.38\n",
        "gc_r = 0.5\n",
        "gste_r = 0.2\n",
        "gser_r = 1.0\n",
        "\n",
        "# Impose roof\n",
        "qimp_r = 1.5\n",
        "\n",
        "# ULS loads\n",
        "Gtyp_f = gt_f + gs_f + gc_f + gste_f + gser_f\n",
        "Qtyp_f = qpar_f + qimp_f\n",
        "wtyp_f = 1.35 * Gtyp_f + 1.5 * Qtyp_f\n",
        "Gtyp_r = gt_r + gs_r + gc_r + gste_r + gser_r\n",
        "Qtyp_r = qimp_r\n",
        "wtyp_r = 1.35 * Gtyp_r + 1.5 * Qtyp_r\n",
        "\n",
        "# Cladding loads specific to beam types & levels\n",
        "p_qclad_f = 0.0 if Typep == 'Internal' else 1.5 * qcl * H * 1e-3\n",
        "s_qclad_f = 0.0 if Types == 'Internal' else 1.5 * qcl * H * 1e-3\n",
        "# Primary beam Ved\n",
        "p_ly = 13500 / 2 if Typep == 'Perimeter' else 13500 \n",
        "SB = 2 if lxl == 8250 else 1\n",
        "p_lb = lxl\n",
        "if SB == 1:\n",
        "    # Floor Calculations\n",
        "    ptotal_f = 1e-6 * wtyp_f * p_lb * p_ly / 2\n",
        "    p_Ved_f = ptotal_f / 2 + p_qclad_f * (p_lb * 1e-3) / 2\n",
        "    \n",
        "    # Roof Calculations\n",
        "    ptotal_r = 1e-6 * wtyp_r * p_lb * p_ly / 2\n",
        "    p_Ved_r = ptotal_r / 2\n",
        "else:\n",
        "    # Floor Calculations\n",
        "    ptotal_f = 1e-6 * wtyp_f * p_lb * p_ly / 3\n",
        "    p_Ved_f = ptotal_f + p_qclad_f * (lxl * 1e-3) / 2\n",
        "    # Roof Calculations\n",
        "    ptotal_r = 1e-6 * wtyp_r * p_lb * p_ly / 3\n",
        "    p_Ved_r = ptotal_r\n",
        "# Ssecondary beam Ved\n",
        "s_ly = 13500\n",
        "qtyp_applied_f = wtyp_f * s_lx * 1e-3\n",
        "qtyp_applied_r = wtyp_r * s_lx * 1e-3\n",
        "if Types == 'Edge':\n",
        "    qtotal_f = s_qclad_f + qtyp_applied_f\n",
        "    qtotal_r =  qtyp_applied_r\n",
        "else:\n",
        "    qtotal_f = qtyp_applied_f\n",
        "    qtotal_r = qtyp_applied_r\n",
        "s_Ved_f = qtotal_f * (s_ly * 1e-3) / 2\n",
        "s_Ved_r = qtotal_r * (s_ly * 1e-3) / 2"
      ],
      "id": "b303f1b0",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "\\Large \n",
        "\\linespread{1.4}\n",
        "\\selectfont \n",
        "\n",
        "# \n",
        "#\n",
        "#\n",
        "#\n",
        "#\n",
        "#\n",
        "\n",
        "# Floor Loads\n",
        "\\begin{multicols}{2}\n",
        "\\begin{description}\n",
        "    \\item[]$G_{tiles}$ = `{python} gt_f` $kN/m^2$\n",
        "    \\item[]$G_{steel}$ = `{python} gste_f` $kN/m^2$\n",
        "    \\item[]$G_{cladding}$ = `{python} gc_f` $kN/m^2$\n",
        "    \\item[]$G_{slab}$ = `{python} gs_f` $kN/m^2$\n",
        "    \\item[]$G_{services}$ = `{python} gser_f` $kN/m^2$\n",
        "    \\item[]$Q_{partitions}$ = `{python} qpar_f` $kN/m^2$\n",
        "    \\item[]$Q_{imposed}$ = `{python} qimp_f` $kN/m^2$\n",
        "    \\item[]$Q_{cladding}$ = `{python} qcl` $kN/m^2$\n",
        "\\end{description}\n",
        "\\end{multicols}\n",
        "\n",
        "# Roof Loads\n",
        "\\begin{multicols}{2}\n",
        "\\begin{description}\n",
        "    \\item[]$G_{tiles}$ = `{python} gt_r` $kN/m^2$\n",
        "    \\item[]$G_{steel}$ = `{python} gste_r` $kN/m^2$\n",
        "    \\item[]$G_{cladding}$ = `{python} gc_r` $kN/m^2$\n",
        "    \\item[]$G_{slab}$ = `{python} gs_r` $kN/m^2$\n",
        "    \\item[]$G_{services}$ = `{python} gser_r` $kN/m^2$\n",
        "    \\item[]$Q_{imposed}$ = `{python} qimp_r` $kN/m^2$\n",
        "\\end{description}\n",
        "\\end{multicols}\n",
        "\n",
        "{{< pagebreak >}}\n",
        "\n",
        "#\n",
        "# ULS floor uniform area load\n",
        "\\begin{description}\n",
        "    \\item[]Typical dead load, $G_{typ,f}$ = $G_{tiles} + G_{steel} + G_{cladding} + G_{slab} + G_{services}$ = `{python} Gtyp_f` $kN/m^2$\n",
        "    \\item[]Typical imposed load, $Q_{typ,f}$ = $Q_{partitions} + Q_{imposed}$ = `{python} Qtyp_f` $kN/m^2$\n",
        "    \\item[]Typical load, $W_{typ,f}$ = $1.35\\cdot G_{typ,f} + 1.5 \\cdot Q_{typ,f}$ = `{python} wtyp_f` $kN/m^2$\n",
        "\\end{description}\n",
        "\n",
        "# ULS roof uniform area load\n",
        "\\begin{description}\n",
        "    \\item[]Typical dead load, $G_{typ,r}$ = $G_{tiles} + G_{steel} + G_{cladding} + G_{slab} + G_{services}$ = `{python} Gtyp_r` $kN/m^2$\n",
        "    \\item[]Typical imposed load, $Q_{typ,r}$ = $Q_{imposed}$ = `{python} Qtyp_r` $kN/m^2$\n",
        "    \\item[]Typical load, $W_{typ,r}$ = $1.35\\cdot G_{typ,r} + 1.5 \\cdot Q_{typ,r}$ = `{python} wtyp_r` $kN/m^2$\n",
        "\\end{description}\n",
        "\n",
        "# According to previous beam calculation sheet\n",
        "\\begin{description}\n",
        "    \\item[]Column height of the floor, $H$ = `{python} H` $mm$\n",
        "    \\item[]Primary reaction force $V_{ed,p} =\\frac{1}{2}\\cdot W_{tpy}\\cdot L_{x}\\cdot L_{y} + \\frac{1}{2}\\cdot Q_{clad}\\cdot L_x \\cdot H$\n",
        "    \\item[]Secondary reaction force $V_{ed,s} = \\frac{q_{uls}\\cdot L_y}{2}$, $q_{uls}$ = $W_{tpy}\\cdot L_x + 1.5\\cdot Q_{clad}\\cdot H$\n",
        "    \\item[]For roof case, the load of cladding will be removed\n",
        "\\end{description}\n",
        "\n",
        "{{< pagebreak >}}"
      ],
      "id": "e2fae2dd"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "import pandas as pd\n",
        "import math\n",
        "\n",
        "df_all = pd.read_csv('section_mm.csv')\n",
        "if df_all.columns[0] == 'Unnamed: 0':\n",
        "  df_all = df_all.rename(columns = {'Unnamed: 0' : 'Section Profile'})\n",
        "\n",
        "# Scientific notation formatter\n",
        "def sci(value):\n",
        "    exp_num = math.floor(math.log10(abs(value)))\n",
        "    base = value / (10 ** exp_num)\n",
        "    return value, base, exp_num\n",
        "\n",
        "#material\n",
        "fu= 500.0\n",
        "fy = 355.0\n",
        "E = 210000\n",
        "G = 81000\n",
        "\n",
        "df = df_all[df_all['Section Profile'] == section]\n",
        "#section\n",
        "h = float(df['h (mm)'].iloc[0])\n",
        "b = float(df['b (mm)'].iloc[0])\n",
        "tw = float(df['tw (mm)'].iloc[0])\n",
        "tf = float(df['tf (mm)'].iloc[0])\n",
        "d = float(df['d (mm)'].iloc[0])\n",
        "r= float(df['r(mm)'].iloc[0])\n",
        "A, A1, A2 = sci(float(df['A (mm^2)'].iloc[0]))\n",
        "Iy, Iy1, Iy2 = sci(float(df['Iy (mm^4)'].iloc[0]))\n",
        "Iz, Iz1, Iz2 = sci(float(df['Iz (mm^4)'].iloc[0]))\n",
        "Ry = float(df['Ry (mm)'].iloc[0])\n",
        "Rz = float(df['Rz (mm)'].iloc[0])\n",
        "Wey, Wey1, Wey2 = sci(float(df['W_el,y (mm^3)'].iloc[0]))\n",
        "Wez, Wez1, Wez2 = sci(float(df['W_el,z (mm^3)'].iloc[0]))\n",
        "Wpy, Wpy1, Wpy2 = sci(float(df['W_pl,y (mm3)'].iloc[0]))\n",
        "Wpz, Wpz1, Wpz2 = sci(float(df['W_pl,z (mm^3)'].iloc[0]))\n",
        "Iw, Iw1, Iw2 = sci(float(df['I_w (mm^6)'].iloc[0]))\n",
        "It, It1, It2 = sci(float(df['I_T (mm^4)'].iloc[0]))\n",
        "\n",
        "ratio = h/b\n",
        "if ratio > 1.2:\n",
        "  if tf <= 40:\n",
        "    ay = 0.21\n",
        "    az = 0.34\n",
        "  else:\n",
        "    ay = 0.34\n",
        "    az = 0.49\n",
        "else:\n",
        "  if tf <= 100:\n",
        "    ay = 0.34\n",
        "    az = 0.49\n",
        "  else:\n",
        "    ay = 0.70\n",
        "    az = 0.70"
      ],
      "id": "00a830ee",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "#\n",
        "# Material Properties\n",
        "\\begin{description}\n",
        "  \\item[]Ultimate strength: $f_{u}$ = `{python} fu` $N\\cdot mm^{-2}$  \n",
        "  \\item[]Yield strength: $f_{y}$ = `{python} fy` $N \\cdot mm^{-2}$  \n",
        "  \\item[]Young modulus: E = `{python} E` $N\\cdot mm^{-2}$  \n",
        "  \\item[]Shear modulus: G = `{python} G` $N\\cdot mm^{-2}$\n",
        "\\end{description}\n",
        "\n",
        "# Section Properties of UC `{python} section`\n",
        "\\begin{multicols}{2}\n",
        "\\begin{description}\n",
        "  \\item[] Overall depth, $h$ = `{python} h` mm  \n",
        "  \\item[] Width of section, $b$ = `{python} b` mm  \n",
        "  \\item[] Web thickness, $t_{w}$ = `{python} tw` mm  \n",
        "  \\item[] Flange thickness, $t_{f}$ = `{python} tf` mm  \n",
        "  \\item[] Depth between fillet, $h_{w}$ = `{python} d` mm  \n",
        "  \\item[] Root radius, $r$ = `{python} r` mm  \n",
        "  \\item[] Area of section, $A$ = `{python} A1` $\\cdot 10^{`{python} A2`}$ $mm^{2}$ \n",
        "  \\item[] 2nd moment Y-Y, $I_{y}$ = `{python} Iy1` $\\cdot 10^{`{python} Iy2`}$ $mm^{4}$  \n",
        "  \\item[] 2nd moment Z-Z, $I_{z}$ = `{python} Iz1` $\\cdot 10^{`{python} Iz2`}$ $mm^{4}$  \n",
        "  \\item[] Radius of gyration Y-Y, $i_{y}$ = `{python} Ry` mm  \n",
        "  \\item[] Radius of gyration Z-Z, $i_{z}$ = `{python} Rz` mm  \n",
        "  \\item[] Elastic modulus Y-Y, $W_{el,y}$ = `{python} Wey1` $\\cdot 10^{`{python} Wey2`}$ $mm^{3}$  \n",
        "  \\item[] Elastic modulus Z-Z, $W_{el,z}$ = `{python} Wez1` $\\cdot 10^{`{python} Wez2`}$ $mm^{3}$  \n",
        "  \\item[] Plastic modulus Y-Y, $W_{pl,y}$ = `{python} Wpy1` $\\cdot 10^{`{python} Wpy2`}$ $mm^{3}$  \n",
        "  \\item[] Plastic modulus Z-Z, $W_{pl,z}$ = `{python} Wpz1` $\\cdot 10^{`{python} Wpz2`}$ $mm^{3}$  \n",
        "  \\item[] Warping constant, $I_{w}$ = `{python} Iw1` $\\cdot 10^{`{python} Iw2`}$ $mm^{6}$  \n",
        "  \\item[] Torsional constant, $I_{t}$ = `{python} It1` $\\cdot 10^{`{python} It2`}$   $mm^{4}$  \n",
        "\\end{description}\n",
        "\\end{multicols}\n",
        "\n",
        "{{< pagebreak >}}"
      ],
      "id": "8b87fba0"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "# Count number of floors above the column\n",
        "num_floor = 9 - floor\n",
        "if num_floor == 8:\n",
        "    nfloor =7.5\n",
        "else: \n",
        "    nfloor = num_floor\n",
        "# eccentricity\n",
        "ecc_y = (100 + h/2)\n",
        "ecc_z = (100 + tw/2)\n",
        "\n",
        "# Axial load and moment on column\n",
        "if Type == 'Edge':\n",
        "  BC =2 \n",
        "  Ned = nfloor*p_Ved_f + p_Ved_r + nfloor*s_Ved_f + s_Ved_r\n",
        "  Myed = p_Ved_f*ecc_y*1e-3\n",
        "  Mzed = s_Ved_f*ecc_z*1e-3\n",
        "elif Type == 'Perimeter1':\n",
        "  BC = 3\n",
        "  Ned = nfloor*p_Ved_f + p_Ved_r + 2*nfloor*s_Ved_f + 2*s_Ved_r\n",
        "  Myed = (s_Ved_f - s_Ved_f)*ecc_y*1e-3\n",
        "  Mzed = p_Ved_f*ecc_z*1e-13\n",
        "elif Type == 'Internal':\n",
        "  BC = 4\n",
        "  Ned = 2*nfloor*p_Ved_f + 2*p_Ved_r + 2*nfloor*s_Ved_f + 2*s_Ved_r\n",
        "  Myed = (p_Ved_f - p_Ved_f)*ecc_y*1e-3\n",
        "  Mzed = (s_Ved_f - s_Ved_f)*ecc_z*1e-3\n",
        "elif Type == 'Perimeter2':\n",
        "  BC = 5\n",
        "  Ned = nfloor*s_Ved_f + s_Ved_r + 2*nfloor*s_Ved_f + 2*p_Ved_r\n",
        "  Myed = p_Ved_f*ecc_y*1e-3\n",
        "  Mzed = (s_Ved_f - s_Ved_f)*ecc_z*1e-13\n",
        "else:\n",
        "  raise ValueError(f\"Unsupported Type: {Type}\")"
      ],
      "id": "66087a38",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "#\n",
        "# Design axial load and moment on column\n",
        "\\begin{description}\n",
        "  \\item[]Number of floors above column = `{python} num_floor`\n",
        "  \\item[]Eccentricity about y-axis, $e_{y}$ = $100 +\\frac{h}{2}$ = `{python} ecc_y` mm\n",
        "  \\item[]Eccentricity about z-axis, $e_{z}$ = $100 +\\frac{tw}{2}$ = `{python} ecc_z` mm\n",
        "  \\item[]$Q_{clad} = 1.35\\cdot Q_{clad}$ = `{python} p_qclad_f` $kN/m$\n",
        "\\end{description}\n",
        "\n",
        "\\setcounter{score}{`{python} int(BC)`}\n",
        "\n",
        "\\ifthenelse{\\value{score}=2}{\n",
        "\\begin{description}\n",
        "  \\item[]Reaction forces for beams connected to edge column, \n",
        "  \\item[]Secondary beam due to floor load, $V_{ed,sf}$ =  `{python} s_Ved_f` kN\n",
        "  \\item[]Secondary beam due to roof load, $V_{ed,sr}$ = `{python} s_Ved_r` kN\n",
        "  \\item[]Primary beam due to floor load, $V_{ed,pf}$ = `{python} p_Ved_f` kN\n",
        "  \\item[]Primary beam due to roof load, $V_{ed,pr}$  = `{python} p_Ved_r` kN\n",
        "  \\item[]Design axial load, $N_{ed}$ = $`{python} nfloor`\\cdot (V_{ed,pf} + V_{ed,sf}) + V_{ed,sr} + V_{ed,pr}$ = `{python} Ned` kN\n",
        "  \\item[]Design moment about y-axis, $M_{y}$ = $V_{ed,pf} \\cdot e_{y}$ = `{python} Myed` kNm\n",
        "  \\item[]Design moment about z-axis, $M_{z}$ = $V_{ed,sf} \\cdot e_{z}$ = `{python} Mzed` kNm\n",
        "\\end{description}\n",
        "}{\n",
        "\\ifthenelse{\\value{score}=3}{\n",
        "\\begin{description}\n",
        "  \\item[]Reaction forces for beams connected to perimeter column, \n",
        "  \\item[]Secondary beam due to floor load, $V_{ed,sf}$ =  `{python} s_Ved_f` kN\n",
        "  \\item[]Secondary beam due to roof load, $V_{ed,sr}$ = `{python} s_Ved_r` kN\n",
        "  \\item[]Primary beam due to floor load, $V_{ed,pf}$ = `{python} p_Ved_f` kN\n",
        "  \\item[]Primary beam due to roof load, $V_{ed,pr}$  = `{python} p_Ved_r` kN\n",
        "  \\item[]Design axial load, $N_{ed}$ = $`{python} nfloor`\\cdot (V_{ed,pf} + 2\\cdot V_{ed,pf}) + V_{ed,pr} + V_{ed,sr}$ = `{python} Ned` kN\n",
        "  \\item[]Design moment about y-axis, $M_{y}$ = $(V_{ed,sf} - V_{ed,sf}) \\cdot e_{y}$ = `{python} Myed` kNm\n",
        "  \\item[]Design moment about z-axis, $M_{z}$ = $V_{ed,pf} \\cdot e_{z}$ = `{python} Mzed` kNm\n",
        "\\end{description}\n",
        "}{\n",
        "\\ifthenelse{\\value{score}=4}{\n",
        "\\begin{description}\n",
        "  \\item[]Reaction forces for beams connected to internal column, \n",
        "  \\item[]Secondary beam due to floor load, $V_{ed,sf}$ =  `{python} s_Ved_f` kN\n",
        "  \\item[]Secondary beam due to roof load, $V_{ed,sr}$ = `{python} s_Ved_r` kN\n",
        "  \\item[]Primary beam due to floor load, $V_{ed,pf}$ = `{python} p_Ved_f` kN\n",
        "  \\item[]Primary beam due to roof load, $V_{ed,pr}$  = `{python} p_Ved_r` kN\n",
        "  \\item[]Design axial load, $N_{ed}$ = $2`{python} nfloor`\\cdot(V_{ed,pf} + V_{ed,sf}) + 2V_{ed,pr} + 2V_{ed,sr}$ = `{python} Ned` kN\n",
        "  \\item[]Design moment about y-axis, $M_{y}$ = $(V_{ed,sf} - V_{ed,sf}) \\cdot e_{y}$ = `{python} Myed` kNm\n",
        "  \\item[]Design moment about z-axis, $M_{z}$ = $(V_{ed,pf} - V_{ed,pf}) \\cdot e_{z}$ = `{python} Mzed` kNm\n",
        "\\end{description}\n",
        "}{\n",
        "\\ifthenelse{\\value{score}=5}{\n",
        "\\begin{description}\n",
        "  \\item[]Reaction forces for Perimeter beams (type 2), \n",
        "  \\item[]Reaction forces for beams connected to internal column, \n",
        "  \\item[]Secondary beam due to floor load, $V_{ed,sf}$ =  `{python} s_Ved_f` kN\n",
        "  \\item[]Secondary beam due to roof load, $V_{ed,sr}$ = `{python} s_Ved_r` kN\n",
        "  \\item[]Primary beam due to floor load, $V_{ed,pf}$ = `{python} p_Ved_f` kN\n",
        "  \\item[]Primary beam due to roof load, $V_{ed,pr}$  = `{python} p_Ved_r` kN\n",
        "  \\item[]Design axial load, $N_{ed}$ = $2`{python} nfloor`\\cdot (V_{ed,sf} + V_{ed,pf}) + V_{ed,sr} + V_{ed,pr}$ = `{python} Ned` kN\n",
        "  \\item[]Design moment about y-axis, $M_{y}$ = $(V_{ed,sf}- V_{ed,sf})\\cdot e_{y}$ = `{python} Myed` kNm\n",
        "  \\item[]Design moment about z-axis, $M_{z}$ = $V_{ed,pf}\\cdot e_{z}$ = `{python} Mzed` kNm\n",
